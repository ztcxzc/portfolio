{
  "name": "adb-device-monitor",
  "version": "1.0.0",
  "description": "Real-time ADB device monitor with screen mirroring",
  "main": "electron/main.js",
  "scripts": {
    "build": "webpack --mode production",
    "start": "npm run build && electron .",
    "dev": "concurrently -k \"webpack --watch --mode development\" \"wait-on public/dist/bundle.js && electron .\"",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "@babel/preset-env": "^7.23.7",
    "@babel/preset-react": "^7.23.3",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "css-loader": "^6.9.1",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "style-loader": "^3.3.4",
    "wait-on": "^7.2.0",
    "webpack": "^5.90.1",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "build": {
    "appId": "com.adb.devicemonitor",
    "productName": "ADB Device Monitor",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "electron/**/*",
      "public/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "electron/adb/mjpeg_bridge.py"
    ]
  }
}
