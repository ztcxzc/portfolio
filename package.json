{
  "name": "portfolio-showcase",
  "version": "1.0.0",
  "description": "Preview-first portfolio showcase for websites, mobile apps, and Mac apps",
  "main": "electron/main.js",
  "scripts": {
    "start": "webpack serve --mode development",
    "build": "webpack --mode production",
    "electron": "npm run build && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "@babel/preset-env": "^7.23.7",
    "@babel/preset-react": "^7.23.3",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "css-loader": "^6.9.1",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "style-loader": "^3.3.4",
    "wait-on": "^7.2.0",
    "webpack": "^5.90.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.4"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "build": {
    "appId": "com.portfolio.showcase",
    "productName": "Portfolio Manager",
    "mac": {
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "category": "public.app-category.productivity"
    },
    "files": [
      "electron/**/*",
      "public/dist/**/*",
      "public/manager.html",
      "node_modules/**/*"
    ],
    "extraResources": [
      { "from": "src/data/projects.json", "to": "projects.json" }
    ]
  }
}
